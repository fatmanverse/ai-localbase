# Ollama service URL used by backend
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Qdrant vector size should match your embedding model
QDRANT_VECTOR_SIZE=768

# Backend and frontend local defaults
QDRANT_URL=http://qdrant:6333
VITE_API_BASE_URL=http://localhost:8080

# Optional: build-time proxy for docker compose / docker build
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal,qdrant,backend,frontend
